# Configurações do Servidor
PORT=5000
NODE_ENV=production

# Conexão com o Banco de Dados (PostgreSQL)
# Local: postgresql://postgres:postgres@localhost:5432/slimo
# Docker Compose: postgresql://postgres:c11560011@db:5432/slimo
DATABASE_URL=postgresql://postgres:c11560011@db:5432/slimo

# Chave secreta para assinatura dos tokens JWT
JWT_SECRET=super_secret_jwt_key_slimo_2026_change_me

# Google OAuth 2.0 Client ID (obtido no Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Gateway de Pagamento (Mercado Pago & Asaas Keys)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-your_mercado_pago_token_here
ASAAS_API_KEY=$aae.your_asaas_api_key_here
